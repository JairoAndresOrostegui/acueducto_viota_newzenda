rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function currentUserData() {
      return get(currentUserPath()).data;
    }

    function isAdmin() {
      return signedIn() &&
          exists(currentUserPath()) &&
          currentUserData().rol == 'administrador' &&
          currentUserData().estado == 'activo';
    }

    function isOperador() {
      return signedIn() &&
          exists(currentUserPath()) &&
          currentUserData().rol == 'operador' &&
          currentUserData().estado == 'activo';
    }

    function canManageConsumptions() {
      return isAdmin() || isOperador();
    }

    match /usuarios/{userId} {
      allow read: if signedIn() &&
          (request.auth.uid == userId ||
              isAdmin() ||
              (isOperador() &&
                  resource.data.rol == 'cliente' &&
                  resource.data.estado == 'activo'));

      allow create, update: if isAdmin() &&
          request.resource.data.uid == userId;

      allow delete: if isAdmin() && request.auth.uid != userId;
    }

    match /tipos_documento/{docId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.estado == 'activo');
      allow create, update, delete: if isAdmin();
    }

    match /roles/{docId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.estado == 'activo');
      allow create, update, delete: if isAdmin();
    }

    match /sectores/{docId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.estado == 'activo');
      allow create, update, delete: if isAdmin();
    }

    match /usuarios_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /periodos/{periodoId} {
      allow read: if canManageConsumptions();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /medios_pago/{medioPagoId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /valores_facturacion/{valorId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /consumos/{consumoId} {
      allow read, create, update: if canManageConsumptions();
      allow delete: if false;
    }

    match /consumos_conflictos/{conflictoId} {
      allow create: if canManageConsumptions();
      allow read: if isAdmin() ||
          (isOperador() && resource.data.actorUid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
